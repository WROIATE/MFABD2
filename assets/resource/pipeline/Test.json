        "next": [
          "Check_Weekly_Task"
        ],
        "timeout": 10000
      }
    }
  },
  "Test_HomePage": {
    "doc": "周触发器测试起点",
    "action": "Custom",
    "custom_action": "CheckCoolDown",
    "custom_action_param": {
      "card_name": "Map_01"
    },
    "next": [
      "Test_HomePage_0"
    ],
    "timeout": 5000,
    "on_error": [
      "Test_HomePage_1"
    ],
    "focus": "G=0.流程启动"
  },
  "Test_HomePage_0": {
    "focus": "测试=0,通过",
    "action": "Custom",
    "custom_action": "MarkComplete",
    "custom_action_param": {
      "card_name": "Map_01",
      "cycle_type": "g_weekly"
    }
  },
  "Test_HomePage_1": {
    "focus": "测试=1,失败"
  },
  "Test_HomePage_B": {
    "doc": "计数器测试起点",
    "next": [
      "Test_HomePage_B_main"
    ],
    "timeout": 2000,
    "on_error": [
      "Test_HomePage_B_Err"
    ]
  },
  "Test_HomePage_B_main": {
    "doc": "检测次数!",
    "recognition": "Custom",
    "custom_recognition": "CheckTag",
    "custom_recognition_param": {
      "tag": "Item_Count",
      "max": 3
    },
    "next": [
      "Test_HomePage_B_Action"
    ],
    "on_error": [
      "Test_HomePage_B_Err"
    ]
  },
  "Test_HomePage_B_Action": {
    "focus": "计数+1了",
    "action": "Custom",
    "custom_action": "UpdateTag",
    "custom_action_param": {
      "tag": "Item_Count",
      "value": 1
    },
    "next": [
      "Test_HomePage_B_main"
    ],
    "timeout": 2000,
    "on_error": [
      "Test_HomePage_B_Err"
    ]
  },
  "Test_HomePage_B_Err": {
    "focus": "失败了",
    "next": [
      "Test_HomePage_C_End"
    ]
  },
  "Test_HomePage_C_End": {
    "focus": "重置Test_HomePage_1",
    "action": "Custom",
    "custom_action": "RestoreNode",
    "custom_action_param": {
      "node": "Test_HomePage_1"
    },
    "next": [
      "Test_HomePage"
    ]
  },
  "Check_Weekly_Task": {
    "next": [
      "Execute_Weekly_Task",
      "Skip_Weekly_Task"
    ],
    "on_error": [
      "errer2"
    ],
    "focus": "G=0. 周任务检查开始。",
    "doc": "使用自定义识别判断本周是否已执行"
  },
  "Execute_Weekly_Task": {
    "recognition": "Custom",
    "custom_recognition": "test_execute_weekly.TestExecuteWeekly",
    "focus": "G=0. 周任务检查开始。T",
    "action": "DoNothing",
    "doc": "本周任务未执行，现在开始执行"
  },
  "Skip_Weekly_Task": {
    "recognition": "Custom",
